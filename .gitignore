# Rust
target/

# Spike: downloaded datasets stay out of the repo (licensing: see BENCHMARK.md).
# spike/out/ results ARE committed (our numbers, tiny, referenced by docs/notebook.md).
spike/data/
spike/.venv/

# `amberfork-bench fetch` cache: raw upstream bench data (GAIA lineage — local
# benchmarking only, never committed; see BENCHMARK.md "Data & licensing").
bench/data/

# Python
__pycache__/
*.pyc

# Built web UI bundle (issue #25, D13): produced by the release workflow (#26/#28), never
# committed — the crates.io package carries it via the crate's Cargo.toml `include` list.
# `.gitkeep` stays tracked because rust-embed needs the folder to exist at compile time.
crates/amberfork-server/ui-dist/*
!crates/amberfork-server/ui-dist/.gitkeep

# The web UI's own trunk build output (ui/, issue #26). The engine workspace's `target/`
# glob above already covers ui/target/; this is trunk's wasm bundle dir.
ui/dist/

# Local tool state
.gstack/
.claude/settings.local.json

# OS
.DS_Store
